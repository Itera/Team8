{
  "name": "humotivatoren",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "tests"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "test": "npm run test --workspace=tests",
    "build": "npm run build --workspace=frontend && npm run build --workspace=backend"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "concurrently": "^9.1.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
